{{- /*
  llms.txt — part of the nginx Hugo theme

  Generates /llms.txt following the llmstxt.org specification.
  Grouped by Hugo sections. Respects:
    params.llms.generate_llms_txt  (bool, default true)
    params.llms.include            (slice of path globs)
    params.llms.exclude            (slice of path globs)
    params.llms.max_per_section    (int, default 0 = unlimited) — caps pages listed per section
    params.llms.sort_by            (string, default "Title") — page field used for ordering

  Per-page opt-out: set `nollms: true` in a page's front matter to exclude it,
  regardless of the include/exclude globs.

  NOTE: per-page/section .md links require a Markdown output format to be enabled
  for the relevant page kinds; otherwise links fall back to the HTML permalink.

  The three inline `define` helpers below register globally and may be extracted
  into their own files under layouts/partials/ if you prefer.
*/ -}}

{{- /* ---------- Helper: glob-based include/exclude matching ---------- */ -}}
{{- define "partials/llms_is_valid_page.html" -}}
{{- $url := .url -}}
{{- $page := .page -}}
{{- $includeList := .includeList -}}
{{- $excludeList := .excludeList -}}
{{- /* Per-page opt-out: `nollms: true` in front matter excludes the page */ -}}
{{- $nollms := false -}}
{{- with $page }}{{ if .Params.nollms }}{{ $nollms = true }}{{ end }}{{- end -}}
{{- $isIncluded := false -}}
{{- if eq (len $includeList) 0 }}{{ $isIncluded = true }}{{ else -}}
{{- range $includeList -}}
  {{- /* "/path/**" => match this path and everything below it */ -}}
  {{- if strings.HasSuffix . "/**" }}{{ if strings.HasPrefix $url (strings.TrimSuffix "/**" .) }}{{ $isIncluded = true }}{{ end -}}
  {{- /* "/path/*" => match only direct children, not deeper descendants */ -}}
  {{- else if strings.HasSuffix . "/*" }}{{ $dir := strings.TrimSuffix "*" . }}{{ if and (strings.HasPrefix $url $dir) (ne $url $dir) (not (strings.Contains (strings.TrimSuffix "/" (strings.TrimPrefix $dir $url)) "/")) }}{{ $isIncluded = true }}{{ end -}}
  {{- /* exact path match */ -}}
  {{- else }}{{ if eq $url . }}{{ $isIncluded = true }}{{ end -}}
  {{- end -}}
{{- end -}}
{{- end -}}
{{- $isExcluded := false -}}
{{- range $excludeList -}}
  {{- if strings.HasSuffix . "/**" }}{{ if strings.HasPrefix $url (strings.TrimSuffix "/**" .) }}{{ $isExcluded = true }}{{ end -}}
  {{- else if strings.HasSuffix . "/*" }}{{ $dir := strings.TrimSuffix "*" . }}{{ if and (strings.HasPrefix $url $dir) (ne $url $dir) (not (strings.Contains (strings.TrimSuffix "/" (strings.TrimPrefix $dir $url)) "/")) }}{{ $isExcluded = true }}{{ end -}}
  {{- else }}{{ if eq $url . }}{{ $isExcluded = true }}{{ end -}}
  {{- end -}}
{{- end -}}
{{- return (and $isIncluded (not $isExcluded) (not $nollms)) -}}
{{- end -}}

{{- /* ---------- Helper: flatten a description to a single clean line ---------- */ -}}
{{- define "partials/llms_clean.html" -}}
{{- return (. | plainify | chomp | replaceRE `\s+` " ") -}}
{{- end -}}

{{- /* ---------- Helper: build one markdown link line ---------- */ -}}
{{- /* Expects a dict with keys: title, url, desc (desc optional). */ -}}
{{- define "partials/llms_link.html" -}}
{{- $title := .title | default "Untitled" -}}
{{- /* escape brackets so titles can't break the [text](url) link syntax */ -}}
{{- $title = $title | replaceRE `\[` `\[` | replaceRE `\]` `\]` -}}
{{- $line := printf "- [%s](%s)" $title .url -}}
{{- with .desc -}}
  {{- $clean := partial "llms_clean.html" . -}}
  {{- with $clean }}{{ $line = printf "%s: %s" $line . }}{{ end -}}
{{- end -}}
{{- return $line -}}
{{- end -}}

{{- /* ============================================================ */ -}}

{{- $llms := site.Params.llms | default dict -}}
{{- if ne ($llms.generate_llms_txt | default true) false -}}
{{- $rawExcludeList := $llms.exclude | default slice -}}
{{- $includeList := $llms.include | default slice -}}
{{- $maxPerSection := int ($llms.max_per_section | default 0) -}}
{{- $sortBy := $llms.sort_by | default "Title" -}}

{{- /* Clean Exclude List (Include takes precedence for exact matches) */ -}}
{{- $excludeList := slice -}}
{{- range $rawExcludeList -}}
  {{- if not (in $includeList .) -}}
    {{- $excludeList = $excludeList | append . -}}
  {{- end -}}
{{- end -}}

# {{ site.Title }}

> {{ partial "llms_clean.html" (site.Params.metadata.description | default site.Params.description | default site.Title) }}

{{- /* ---------- Pages: collect first, then emit header only if non-empty ---------- */ -}}
{{- $pageLines := slice -}}

{{- /* Home page */ -}}
{{- $home := site.Home -}}
{{- if partial "llms_is_valid_page.html" (dict "url" $home.RelPermalink "page" $home "includeList" $includeList "excludeList" $excludeList) -}}
  {{- $url := $home.Permalink -}}
  {{- with $home.OutputFormats.Get "md" }}{{ $url = .Permalink }}{{ end -}}
  {{- $pageLines = $pageLines | append (partial "llms_link.html" (dict "title" ($home.Title | default "Home") "url" $url "desc" $home.Params.description)) -}}
{{- end -}}

{{- /* Standalone section pages (top-level sections with no pages at any depth) */ -}}
{{- range site.Home.Sections -}}
  {{- if and (not .RegularPagesRecursive) .Title .Permalink -}}
    {{- if partial "llms_is_valid_page.html" (dict "url" .RelPermalink "page" . "includeList" $includeList "excludeList" $excludeList) -}}
      {{- $url := .Permalink -}}
      {{- with .OutputFormats.Get "md" }}{{ $url = .Permalink }}{{ end -}}
      {{- $pageLines = $pageLines | append (partial "llms_link.html" (dict "title" .Title "url" $url "desc" .Params.description)) -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- /* Root-level regular pages: About, Contact, etc. */ -}}
{{- range site.Home.RegularPages -}}
  {{- if partial "llms_is_valid_page.html" (dict "url" .RelPermalink "page" . "includeList" $includeList "excludeList" $excludeList) -}}
    {{- $url := .Permalink -}}
    {{- with .OutputFormats.Get "md" }}{{ $url = .Permalink }}{{ end -}}
    {{- $desc := .Params.description | default (.Summary | plainify | truncate 120) -}}
    {{- $pageLines = $pageLines | append (partial "llms_link.html" (dict "title" .Title "url" $url "desc" $desc)) -}}
  {{- end -}}
{{- end -}}

{{- if $pageLines }}

## Pages

{{ delimit $pageLines "\n" }}
{{- end }}

{{- /* ---------- Content sections: Blog, Docs, etc. ---------- */ -}}
{{- range site.Home.Sections }}
{{- if .RegularPagesRecursive }}
{{- $section := . }}
{{- $validPages := where .RegularPagesRecursive ".Permalink" "ne" "" }}
{{- $validPages = sort $validPages $sortBy }}
{{- $filteredPages := slice }}
{{- range $validPages }}
  {{- if partial "llms_is_valid_page.html" (dict "url" .RelPermalink "page" . "includeList" $includeList "excludeList" $excludeList) }}
    {{- $filteredPages = $filteredPages | append . }}
  {{- end }}
{{- end }}
{{- if and (gt $maxPerSection 0) (gt (len $filteredPages) $maxPerSection) }}
  {{- $filteredPages = first $maxPerSection $filteredPages }}
{{- end }}
{{- if $filteredPages }}
{{- $sectionLines := slice }}
{{- range $filteredPages }}
  {{- if .Title }}
    {{- $url := .Permalink }}
    {{- with .OutputFormats.Get "md" }}{{ $url = .Permalink }}{{ end }}
    {{- $desc := .Params.description | default (.Summary | plainify | truncate 120) }}
    {{- $sectionLines = $sectionLines | append (partial "llms_link.html" (dict "title" .Title "url" $url "desc" $desc)) }}
  {{- end }}
{{- end }}

## {{ $section.Title }}
{{- $sectionUrl := $section.Permalink }}
{{- with $section.OutputFormats.Get "md" }}{{ $sectionUrl = .Permalink }}{{ end }}
{{ partial "llms_link.html" (dict "title" $section.Title "url" $sectionUrl "desc" $section.Params.description) }}
{{ delimit $sectionLines "\n" }}
{{- end }}
{{- end }}
{{- end }}

{{- /* ---------- Taxonomy pages ---------- */ -}}
{{- range $taxonomyName, $taxonomy := site.Taxonomies }}
{{- $taxPage := site.GetPage $taxonomyName }}
{{- if $taxPage }}
{{- if partial "llms_is_valid_page.html" (dict "url" $taxPage.RelPermalink "page" $taxPage "includeList" $includeList "excludeList" $excludeList) }}
{{- $termLines := slice }}
{{- range $termName, $weightedPages := $taxonomy }}
  {{- $termPage := site.GetPage (printf "%s/%s" $taxonomyName $termName) }}
  {{- if $termPage }}
    {{- if partial "llms_is_valid_page.html" (dict "url" $termPage.RelPermalink "page" $termPage "includeList" $includeList "excludeList" $excludeList) }}
      {{- $url := $termPage.Permalink }}
      {{- with $termPage.OutputFormats.Get "md" }}{{ $url = .Permalink }}{{ end }}
      {{- $termLines = $termLines | append (partial "llms_link.html" (dict "title" ($termPage.Title | default $termName) "url" $url "desc" $termPage.Params.description)) }}
    {{- end }}
  {{- end }}
{{- end }}

## {{ $taxPage.Title | default ($taxonomyName | humanize) }}
{{- $taxUrl := $taxPage.Permalink }}
{{- with $taxPage.OutputFormats.Get "md" }}{{ $taxUrl = .Permalink }}{{ end }}
{{ partial "llms_link.html" (dict "title" ($taxPage.Title | default ($taxonomyName | humanize)) "url" $taxUrl "desc" $taxPage.Params.description) }}
{{- with $termLines }}
{{ delimit . "\n" }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

{{- end -}}